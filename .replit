modules = ["nodejs-20", "web", "bash"]

[deployment]
router = "application"
deploymentTarget = "autoscale"
run = ["bash", "-c", "PORT=8080 NODE_ENV=production node artifacts/api-server/dist/index.mjs"]
build = ["bash", "-c", "pnpm --filter @workspace/api-server run build && BASE_PATH=/ pnpm --filter @workspace/mobility-platform run build"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8080 pnpm --filter @workspace/api-server run dev & PORT=22817 BASE_PATH=/ pnpm --filter @workspace/mobility-platform run dev"
waitForPort = 22817

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 9998
externalPort = 3003

[[ports]]
localPort = 9999
externalPort = 3001

[[ports]]
localPort = 22817
externalPort = 3000

[nix]
packages = ["nano"]
channel = "stable-25_05"
